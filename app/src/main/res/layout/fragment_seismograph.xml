<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:padding="12dp" android:background="@color/background">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
        <com.google.android.material.button.MaterialButton android:id="@+id/btnSeismoToggle"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="⏺ Запись" android:layout_marginEnd="8dp" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btnSeismoClear"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="🗑 Очистить"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="@color/divider" android:textColor="@color/text_secondary"
            xmlns:app="http://schemas.android.com/apk/res-auto" />
    </LinearLayout>
    <TextView android:id="@+id/tvSeismoHint" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textSize="12sp" android:textColor="@color/text_secondary" android:layout_marginTop="8dp" />
    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:layout_marginTop="8dp">
        <TextView android:id="@+id/tvSeismoGraph" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:fontFamily="monospace" android:textSize="9sp" android:textColor="#00FF41" android:background="#000000" android:padding="4dp" />
    </ScrollView>
    <TextView android:id="@+id/tvSeismoStats" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textSize="13sp" android:textColor="@color/text_primary" android:layout_marginTop="8dp" android:gravity="center" />
</LinearLayout>
