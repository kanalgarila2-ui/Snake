<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ТЕМА ПРИЛОЖЕНИЯ"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:textAllCaps="true" />

        <RadioGroup
            android:id="@+id/rgTheme"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">

            <RadioButton
                android:id="@+id/rbLight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☀️  Светлая"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:buttonTint="@color/primary" />

            <RadioButton
                android:id="@+id/rbDark"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌙  Тёмная"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:buttonTint="@color/primary" />

            <RadioButton
                android:id="@+id/rbAmoled"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚫  AMOLED (чёрный)"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:buttonTint="@color/primary" />
        </RadioGroup>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/divider" android:layout_marginTop="20dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="API КЛЮЧИ"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:textAllCaps="true"
            android:layout_marginTop="20dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:hintTextColor="@color/primary"
            android:layout_marginTop="8dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSettingsChatKey"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="ChatGPT API ключ (sk-...)"
                android:inputType="textPassword" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:hintTextColor="@color/primary"
            android:layout_marginTop="8dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSettingsWeatherKey"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="OpenWeatherMap API ключ"
                android:inputType="textPassword" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveKeys"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💾 Сохранить ключи"
            android:layout_marginTop="12dp" />

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/divider" android:layout_marginTop="20dp" />

        <TextView
            android:id="@+id/tvSettingsInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="16dp"
            android:lineSpacingMultiplier="1.5" />

    </LinearLayout>
</ScrollView>
