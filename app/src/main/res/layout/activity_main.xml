<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_main.xml — Главный экран приложения ТряскаФон
    Все элементы вертикально по центру, Material Design стиль
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/background">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <!-- Заголовок приложения -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:fontFamily="sans-serif-medium"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="16dp" />

        <!-- Иконка -->
        <ImageView
            android:id="@+id/ivShakeIcon"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_shake"
            app:tint="@color/primary"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp"
            tools:ignore="ContentDescription" />

        <!-- === ГЛАВНЫЙ ПЕРЕКЛЮЧАТЕЛЬ === -->
        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchActivate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/activate_detector"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            app:layout_constraintTop_toBottomOf="@id/ivShakeIcon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="24dp"
            android:checked="false" />

        <!-- === СТАТУС СЕРВИСА === -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/service_stopped"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:background="@drawable/bg_status"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            app:layout_constraintTop_toBottomOf="@id/switchActivate"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp" />

        <!-- === РАЗДЕЛИТЕЛЬ === -->
        <View
            android:id="@+id/divider1"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            app:layout_constraintTop_toBottomOf="@id/tvStatus"
            android:layout_marginTop="24dp" />

        <!-- === ПУТЬ К MP3 === -->
        <TextView
            android:id="@+id/labelFilePath"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/label_file_path"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            app:layout_constraintTop_toBottomOf="@id/divider1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="20dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilFilePath"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:hintTextColor="@color/primary"
            app:boxStrokeColor="@color/primary"
            app:layout_constraintTop_toBottomOf="@id/labelFilePath"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="4dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etFilePath"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_file_path"
                android:inputType="textUri"
                android:textSize="14sp"
                android:maxLines="2"
                android:imeOptions="actionDone"
                android:textColor="@color/text_primary" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Кнопка "Выбрать файл" -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPickFile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_pick_file"
            android:textSize="14sp"
            app:icon="@android:drawable/ic_menu_search"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="@color/primary"
            android:textColor="@color/primary"
            app:layout_constraintTop_toBottomOf="@id/tilFilePath"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp" />

        <!-- === РАЗДЕЛИТЕЛЬ === -->
        <View
            android:id="@+id/divider2"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            app:layout_constraintTop_toBottomOf="@id/btnPickFile"
            android:layout_marginTop="20dp" />

        <!-- === СТАТИСТИКА ТРЯСОК === -->
        <TextView
            android:id="@+id/tvLastShake"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/last_shake_never"
            android:textSize="15sp"
            android:textColor="@color/text_primary"
            app:layout_constraintTop_toBottomOf="@id/divider2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/tvShakeCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/shake_count_zero"
            android:textSize="15sp"
            android:textColor="@color/text_primary"
            app:layout_constraintTop_toBottomOf="@id/tvLastShake"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="4dp" />

        <!-- === PROGRESSBAR ГРОМКОСТИ === -->
        <TextView
            android:id="@+id/labelVolume"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/label_volume"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            app:layout_constraintTop_toBottomOf="@id/tvShakeCount"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="16dp" />

        <ProgressBar
            android:id="@+id/progressBarVolume"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="0dp"
            android:layout_height="12dp"
            android:progress="0"
            android:max="100"
            android:progressTint="@color/primary"
            android:progressBackgroundTint="@color/divider"
            app:layout_constraintTop_toBottomOf="@id/labelVolume"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="4dp" />

        <!-- === РАЗДЕЛИТЕЛЬ === -->
        <View
            android:id="@+id/divider3"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            app:layout_constraintTop_toBottomOf="@id/progressBarVolume"
            android:layout_marginTop="20dp" />

        <!-- === ЧУВСТВИТЕЛЬНОСТЬ === -->
        <TextView
            android:id="@+id/labelSensitivity"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/label_sensitivity"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            app:layout_constraintTop_toBottomOf="@id/divider3"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="20dp" />

        <TextView
            android:id="@+id/tvSensitivityValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="15 м/с²"
            android:textSize="14sp"
            android:textColor="@color/primary"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/divider3"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="20dp" />

        <SeekBar
            android:id="@+id/seekBarSensitivity"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:min="5"
            android:max="30"
            android:progress="15"
            android:progressTint="@color/primary"
            android:thumbTint="@color/primary"
            app:layout_constraintTop_toBottomOf="@id/tvSensitivityValue"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvSensitivityHint"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/sensitivity_hint"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            app:layout_constraintTop_toBottomOf="@id/seekBarSensitivity"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="2dp" />

        <!-- === ВИБРАЦИЯ === -->
        <CheckBox
            android:id="@+id/checkBoxVibrate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/vibrate_on_shake"
            android:textSize="15sp"
            android:textColor="@color/text_primary"
            android:buttonTint="@color/primary"
            app:layout_constraintTop_toBottomOf="@id/tvSensitivityHint"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="20dp"
            android:checked="false" />

        <!-- === ВЕРСИЯ ПРИЛОЖЕНИЯ === -->
        <TextView
            android:id="@+id/tvVersion"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/app_version"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/checkBoxVibrate"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="16dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>
