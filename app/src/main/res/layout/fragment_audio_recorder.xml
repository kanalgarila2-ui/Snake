<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="center_horizontal"
    android:background="@color/background">

    <TextView
        android:id="@+id/tvRecStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Готов"
        android:textSize="18sp"
        android:textColor="@color/text_secondary"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvRecTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="00:00"
        android:textSize="56sp"
        android:textStyle="bold"
        android:textColor="@color/primary"
        android:layout_marginTop="8dp"
        android:fontFamily="monospace" />

    <!-- Уровень сигнала -->
    <ProgressBar
        android:id="@+id/progressRecLevel"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="16dp"
        android:max="100"
        android:progress="0"
        android:progressTint="#F44336"
        android:progressBackgroundTint="@color/divider"
        android:layout_marginTop="16dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnRecord"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:text="⏺"
        android:textSize="48sp"
        android:layout_marginTop="24dp"
        app:cornerRadius="80dp"
        xmlns:app="http://schemas.android.com/apk/res-auto" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginTop="24dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Записи (тап = воспроизвести):"
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        android:textAllCaps="true"
        android:layout_marginTop="12dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp">

        <TextView
            android:id="@+id/tvRecordings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Нет записей"
            android:textSize="13sp"
            android:textColor="@color/text_primary"
            android:fontFamily="monospace"
            android:lineSpacingMultiplier="1.4" />
    </ScrollView>
</LinearLayout>
