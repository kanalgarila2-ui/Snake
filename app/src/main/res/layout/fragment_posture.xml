<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:gravity="center" android:padding="20dp" android:background="@color/background">
    <TextView android:id="@+id/tvPostureScore" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Нажми Мониторить" android:textSize="22sp" android:textStyle="bold"
        android:textColor="@color/primary" android:gravity="center" />
    <ProgressBar android:id="@+id/progressPosture" style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent" android:layout_height="20dp"
        android:max="100" android:progress="50" android:progressTint="@color/primary"
        android:layout_marginTop="16dp" />
    <TextView android:id="@+id/tvPostureAngle" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textSize="16sp" android:textColor="@color/text_primary" android:gravity="center"
        android:fontFamily="monospace" android:layout_marginTop="16dp" android:lineSpacingMultiplier="1.5" />
    <com.google.android.material.button.MaterialButton android:id="@+id/btnPostureToggle"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="▶ Мониторить" android:layout_marginTop="24dp" />
    <TextView android:id="@+id/tvPostureHint" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textSize="12sp" android:textColor="@color/text_secondary" android:gravity="center"
        android:layout_marginTop="12dp" android:lineSpacingMultiplier="1.4" />
</LinearLayout>
