<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:gravity="center" android:padding="24dp" android:background="@color/background">
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="⛏" android:textSize="80sp" android:gravity="center" />
    <TextView android:id="@+id/tvMiningHash" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="—" android:textSize="13sp" android:fontFamily="monospace" android:textColor="#00FF41"
        android:background="#000000" android:padding="8dp" android:gravity="center" android:layout_marginTop="8dp" />
    <ProgressBar android:id="@+id/progressMining" style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent" android:layout_height="12dp" android:max="100"
        android:progressTint="@color/primary" android:layout_marginTop="8dp" />
    <TextView android:id="@+id/tvMiningStats" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textSize="14sp" android:textColor="@color/text_primary" android:fontFamily="monospace"
        android:lineSpacingMultiplier="1.5" android:layout_marginTop="16dp" android:gravity="center" />
    <com.google.android.material.button.MaterialButton android:id="@+id/btnMineToggle"
        android:layout_width="match_parent" android:layout_height="64dp" android:text="⛏ Майнить!"
        android:textSize="20sp" android:layout_marginTop="24dp" />
    <TextView android:id="@+id/tvMiningDisclaimer" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textSize="11sp" android:textColor="@color/text_secondary" android:gravity="center" android:layout_marginTop="12dp" />
</LinearLayout>
