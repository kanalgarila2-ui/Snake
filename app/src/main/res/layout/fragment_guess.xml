<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="center"
    android:background="@color/background">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔢 Угадайка"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/primary"
        android:gravity="center" />

    <TextView
        android:id="@+id/tvRange"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Диапазон: [1 … 100]"
        android:textSize="20sp"
        android:textColor="@color/text_primary"
        android:gravity="center"
        android:layout_marginTop="24dp" />

    <ProgressBar
        android:id="@+id/progressGuess"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="12dp"
        android:progress="0"
        android:max="100"
        android:progressTint="@color/primary"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/tvGuessResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Нажми «Новая игра»"
        android:textSize="16sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:layout_marginTop="16dp"
        android:minLines="2" />

    <TextView
        android:id="@+id/tvShakeCount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Трясок: 0"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:gravity="center" />

    <!-- Кнопки угадывания -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="20dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGuessLow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="1"
            android:layout_marginEnd="4dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="@color/primary"
            android:textColor="@color/primary"
            xmlns:app="http://schemas.android.com/apk/res-auto"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGuessMid"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="50 (середина)"
            android:layout_marginHorizontal="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGuessHigh"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="100"
            android:layout_marginStart="4dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="@color/primary"
            android:textColor="@color/primary"
            xmlns:app="http://schemas.android.com/apk/res-auto"/>
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNewGame"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔄 Новая игра"
        android:layout_marginTop="16dp" />

</LinearLayout>
