<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Базовая тема приложения ТряскаФон -->
    <style name="Theme.TryaskaFon" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/colorOnPrimary</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorSecondaryVariant">@color/colorSecondaryVariant</item>
        <item name="colorOnSecondary">@color/colorOnSecondary</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorError">@color/colorError</item>
        <item name="colorOnError">@color/colorOnError</item>

        <!-- Убираем ActionBar — используем только контент -->
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>

        <!-- Статус-бар -->
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:navigationBarColor">@color/background</item>
    </style>

    <!-- Тема для SplashScreen (опционально) -->
    <style name="Theme.TryaskaFon.Splash" parent="Theme.TryaskaFon">
        <item name="android:windowBackground">@color/primary</item>
    </style>
</resources>
