<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Разрешения на работу с сенсором в фоне -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />

    <!-- Хранилище: до Android 11 -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- Android 13+ медиа -->
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />

    <!-- Уведомления (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Интернет (для GitHub Actions badge и т.д.) -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- WakeLock — чтобы сервис не засыпал -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Вибрация при тряске -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Акселерометр — желательная фича -->
    <uses-feature
        android:name="android.hardware.sensor.accelerometer"
        android:required="false" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_shake"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_shake"
        android:supportsRtl="true"
        android:theme="@style/Theme.TryaskaFon"
        tools:targetApi="34">

        <!-- Главная Activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Foreground Service детектора тряски -->
        <service
            android:name=".service.ShakeDetectorService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

        <!-- Broadcast receiver для событий тряски -->
        <receiver
            android:name=".receiver.ShakeBroadcastReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.tryaskafon.shake.SHAKE_DETECTED" />
                <action android:name="com.tryaskafon.shake.SERVICE_STOPPED" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
